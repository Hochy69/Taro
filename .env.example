# App
APP_NAME=Tarot Mini App
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-random-64-char-string
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://tarot:tarot_secret@localhost:5432/tarot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBAPP_URL=https://your-domain.com
TELEGRAM_REQUIRED_CHANNEL=best1taro
TELEGRAM_CHANNEL_SUBSCRIBE_REQUIRED=false
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# AI Provider: openai | claude | gemini | openrouter
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
TEMPLATE_ONLY=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Admin
ADMIN_JWT_SECRET=change-me-admin-secret
ADMIN_SECRET_WORD=TaroVlad
FIRST_ADMIN_TELEGRAM_ID=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Limits
FREE_DAILY_SPREADS=1
FREE_SPREADS_PER_PERIOD=3
FREE_SPREAD_PERIOD_DAYS=3
PREMIUM_DAILY_SPREADS=15
FREE_HISTORY_LIMIT=5

# Pricing (Telegram Stars)
PRICE_SINGLE_SPREAD=59
PRICE_SUBSCRIPTION_1M=399
PRICE_SUBSCRIPTION_3M=999
PRICE_SUBSCRIPTION_6M=1799
PRICE_COMPATIBILITY=79
PRICE_SPREAD_PACK_3=149
PRICE_SPREAD_PACK_5=229
FIRST_PAID_DISCOUNT_PERCENT=30
LOVE_BUNDLE_DISCOUNT_PERCENT=20
REFERRAL_PREMIUM_TRIAL_DAYS=3

# Telegram Affiliate Program (Star Ref) — docs/telegram-affiliate-program.md
# AFFILIATE_COMMISSION_PERMILLE=250
# AFFILIATE_DURATION_MONTHS=3
# TELEGRAM_API_ID=
